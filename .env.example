BOT_TOKEN=paste-your-telegram-bot-token-here
BOT_DB_PATH=bot.db

# Optional: route all Telegram API requests through a proxy (e.g. if
# Telegram is blocked on the server's network). Leave empty to disable.
# Supported schemes: socks5://, socks4://, http://
# Example: socks5://user:pass@1.2.3.4:1080
BOT_PROXY_URL=

# Optional: set to true if the bot fails to connect with an SSL error like
# "self-signed certificate in certificate chain" — this is usually caused
# by local antivirus/security software (e.g. Kaspersky) that intercepts
# HTTPS traffic with its own certificate. Enabling this makes the bot also
# trust the Windows/macOS/Linux system certificate store, not just its
# bundled certifi list. Leave false/empty if you don't see this error.
BOT_TRUST_SYSTEM_CERTS=
